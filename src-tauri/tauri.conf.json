{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "D.W.I.F.",
  "version": "1.0.0",
  "identifier": "com.dwif.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "D.W.I.F.",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../index.mjs": "index.mjs",
      "../lib/": "lib/",
      "../scripts/": "scripts/",
      "../node_modules/": "node_modules/",
      "../input/": "input/",
      "../output/": "output/",
      "../package.json": "package.json",
      "../vendor/node.exe": "bin/node.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
